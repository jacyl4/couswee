{
  "name": "couswee",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 4321",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "go:test": "GOCACHE=$PWD/.cache/go-build GOPATH=$PWD/.cache/go-path /usr/local/go/bin/go test ./...",
    "go:run": "COUSWEE_STATIC_DIR=web/dist GOCACHE=$PWD/.cache/go-build GOPATH=$PWD/.cache/go-path /usr/local/go/bin/go run ./cmd/couswee",
    "test": "npm run build && npm run go:test",
    "web:unit": "node --test web/src/lib/*.test.js"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.59.1",
    "svelte": "^5.55.5",
    "vite": "^8.0.12"
  }
}
